{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanna.dev/schemas/calibration/freeze_manifest/v1.json",
  "title": "SAN-881 calibration FREEZE-MANIFEST (Phase B forward reference)",
  "description": "Shape of reference/calibration/FREEZE-MANIFEST.json, the artifact measure.py refuses to run without. Produced at the end of the staged-adjudication workflow documented in README.md; NOT produced in Phase A. All hashes are raw SHA-256 hex digests over the exact committed bytes of the named artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "corpus_version",
    "corpus_inputs_sha256",
    "labels_frozen_sha256",
    "design_metadata_sha256",
    "coverage_manifest_sha256",
    "evaluation_profile_sha256",
    "algorithm_sha256",
    "tables_sha256",
    "adjudication_log_sha256"
  ],
  "properties": {
    "corpus_version": { "const": 1 },
    "corpus_inputs_sha256": { "$ref": "#/$defs/hex64" },
    "labels_frozen_sha256": { "$ref": "#/$defs/hex64" },
    "design_metadata_sha256": { "$ref": "#/$defs/hex64" },
    "coverage_manifest_sha256": { "$ref": "#/$defs/hex64" },
    "evaluation_profile_sha256": { "$ref": "#/$defs/hex64" },
    "algorithm_sha256": {
      "$ref": "#/$defs/hex64",
      "const": "979cf1368fb3cdc6e51b78eaa200a8bcef81e03bfcdc6e89a6c1667b30c16c58"
    },
    "tables_sha256": {
      "$ref": "#/$defs/hex64",
      "const": "0a18dd94bc811bb3166a4f8812e78f2b053a9f8f083b781a21fb0f8371f54ecc"
    },
    "adjudication_log_sha256": { "$ref": "#/$defs/hex64" }
  },
  "$defs": {
    "hex64": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
