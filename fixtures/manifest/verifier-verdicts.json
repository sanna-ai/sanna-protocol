{
  "$schema": "https://sanna.dev/fixtures/verifier-verdicts/v1.json",
  "$comment": "SAN-358 Prompt C: Cross-SDK verifier verdict fixture. Both Python (verify_session_manifest_receipt / verify_invocation_anomaly_receipt) and TypeScript (verifySessionManifestReceipt / verifyInvocationAnomalyReceipt) must produce these exact check arrays on the given receipt inputs. Byte-equal message text is the formal cross-SDK gate.",
  "vectors": [
    {
      "id": "VV-001",
      "description": "Passing session_manifest (gateway, mcp surface, one delivered + one suppressed)",
      "mode": "single",
      "receipt": {
        "event_type": "session_manifest",
        "extensions": {"com.sanna.manifest": {"version": "0.1", "composition_basis": "static", "surfaces": {"mcp": {"tools_delivered": ["read_data"], "tools_suppressed": ["delete_all"], "suppression_reasons": {"delete_all": "cannot_execute"}}}}},
        "constitution_ref": {"policy_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"},
        "enforcement_surface": "gateway"
      },
      "expected_checks": [
        {"name": "manifest_extension_present", "status": "PASS", "message": "extension 'com.sanna.manifest' present"},
        {"name": "manifest_version_supported", "status": "PASS", "message": "manifest version '0.1' is supported"},
        {"name": "manifest_has_at_least_one_surface", "status": "PASS", "message": "manifest surfaces present: ['mcp']"},
        {"name": "manifest_lists_sorted", "status": "PASS", "message": "all surface lists are sorted alphabetically"},
        {"name": "manifest_suppression_reasons_in_enum", "status": "PASS", "message": "all suppression_reasons are in the stable enum"},
        {"name": "manifest_no_overlap_delivered_suppressed", "status": "PASS", "message": "no overlap between delivered and suppressed"},
        {"name": "manifest_suppression_reasons_keys_match", "status": "PASS", "message": "suppression_reasons keys match suppressed names"},
        {"name": "manifest_constitution_ref_present", "status": "PASS", "message": "constitution_ref.policy_hash present"},
        {"name": "manifest_enforcement_surface_consistent", "status": "PASS", "message": "enforcement_surface='gateway' is consistent with surfaces"}
      ]
    },
    {
