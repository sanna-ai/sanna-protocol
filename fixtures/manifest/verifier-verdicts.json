        "constitution_ref": {"policy_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"},
        "enforcement_surface": "gateway"
      },
      "expected_checks": [
        {"name": "manifest_extension_present", "status": "FAIL", "message": "session_manifest receipt missing required extension 'com.sanna.manifest'"},
        {"name": "manifest_constitution_ref_present", "status": "PASS", "message": "constitution_ref.policy_hash present"},
        {"name": "manifest_enforcement_surface_consistent", "status": "FAIL", "message": "session_manifest with enforcement_surface='gateway' missing 'mcp' surface"}
      ]
    },
