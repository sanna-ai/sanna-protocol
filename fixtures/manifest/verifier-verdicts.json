      "receipt": {
        "event_type": "session_manifest",
        "extensions": {"com.sanna.manifest": {"version": "0.1", "composition_basis": "static", "surfaces": {"mcp": {"tools_delivered": ["tool_a"], "tools_suppressed": ["tool_a"], "suppression_reasons": {"tool_a": "cannot_execute"}}}}},
        "constitution_ref": {"policy_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"},
        "enforcement_surface": "gateway"
