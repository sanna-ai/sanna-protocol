      "expected_fail_checks": [
        {"name": "manifest_no_overlap_delivered_suppressed", "status": "FAIL", "message": "manifest surface 'mcp' has 'tool_a' in BOTH delivered and suppressed (anti-enumeration integrity violated)"}
      ]
    },
